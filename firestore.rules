/*
 * Firestore Security Rules for TT_Coach Community Drills
 *
 * MANUAL DEPLOYMENT REQUIRED
 * These rules are NOT auto-deployed by the build or CI/CD. To activate them:
 * 1. Via Firebase CLI: firebase deploy --only firestore:rules
 * 2. Via Firebase Console: go to Firestore → Rules → paste this file
 *
 * CAUTION: Deploying these rules switches Firestore from whatever is currently
 * live to THIS file wholesale. Before deploying to production, ensure:
 * - The 'sessions' and 'users' placeholder rules below match the app's real
 *   access needs (they are conservative authenticated-only stubs).
 * - All 'community_drills' collection rules are tested against the live app flow.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Community Drills public collection
    match /community_drills/{docId} {
      // Anyone can read a community drill (public browsing)
      allow read: if true;

      // Only a signed-in non-anonymous user can create, setting their own UID and zero aggregates
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.ratingSum == 0
        && request.resource.data.ratingCount == 0;

      // Only the creator can delete their drill
      allow delete: if request.auth != null
        && resource.data.creatorUid == request.auth.uid;

      // Only ratingSum and ratingCount may be updated (by the rating subcollection transaction)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingSum', 'ratingCount']);

      // Ratings subcollection: each document is keyed by the rater's UID
      match /ratings/{uid} {
        // Anyone can read ratings (public, and allows a user to fetch their own prior rating)
        allow read: if true;

        // Only the owner of uid can write (create/update/delete) their rating
        // Stars must be an integer in [1, 5] on writes that set data
        allow write: if request.auth != null
          && request.auth.uid == uid
          && (request.method == 'delete'
              || (request.resource.data.stars is int
                  && request.resource.data.stars >= 1
                  && request.resource.data.stars <= 5));
      }
    }

    // TODO: tighten to owner-only before production deploy
    match /sessions/{id} {
      allow read, write: if request.auth != null;
    }

    // TODO: tighten to owner-only (request.auth.uid == id) before production deploy
    match /users/{id} {
      allow read, write: if request.auth != null;
    }

  }
}
