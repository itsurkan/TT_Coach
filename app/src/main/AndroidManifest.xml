<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Declare features -->
    <uses-feature android:name="android.hardware.camera" />

    <!-- Declare permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".TTCoachApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:taskAffinity=""
        android:theme="@style/AppTheme"
        tools:ignore="AllowBackup">

        <!-- Debug Activity - Video Testing (Development Mode) -->
        <activity
            android:name=".DebugActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Login Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Welcome Screen -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="false" />

        <!-- Exercise Selection Screen -->
        <activity
            android:name=".ExerciseSelectionActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Training Screen -->
        <activity
            android:name=".TrainingActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Settings Screen -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Activity Settings Screen -->
        <activity
            android:name=".ActivitySettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- App Settings Screen -->
        <activity
            android:name=".AppSettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Subscribe Screen -->
        <activity
            android:name=".SubscribeActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Main Activity (New Entry Point) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Declare notch support -->
            <meta-data
                android:name="android.notch_support"
                android:value="true" />
        </activity>

        <!-- Camera Activity with MediaPipe -->
        <activity
            android:name=".CameraActivity"
            android:exported="false">
            <!-- Declare notch support -->
            <meta-data
                android:name="android.notch_support"
                android:value="true" />
        </activity>
    </application>

</manifest>