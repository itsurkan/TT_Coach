<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Timer Overlay (Top Center) -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_overlay_pill"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="@string/placeholder_duration"
        android:textColor="@color/ttc_text_1"
        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Stats Overlay (Top Corners) -->
    <LinearLayout
        android:id="@+id/layout_hits_stat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_overlay_pill"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_hits"
            android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
            android:textColor="@color/ttc_text_3"/>

        <TextView
            android:id="@+id/tv_hits_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_hits"
            android:textAppearance="@style/TextAppearance.TTC.Stat.Small"
            android:textColor="@color/ttc_gold_accent"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_accuracy_stat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_overlay_pill"
        android:padding="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_accuracy"
            android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
            android:textColor="@color/ttc_text_3"/>

        <TextView
            android:id="@+id/tv_accuracy_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_percent"
            android:textAppearance="@style/TextAppearance.TTC.Stat.Small"
            android:textColor="@color/ttc_gold_accent"/>
    </LinearLayout>

    <!-- Pause/Play Button (Center) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_pause_play"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_media_pause"
        android:contentDescription="Pause/Resume"
        app:backgroundTint="@color/ttc_gold_bright"
        app:tint="@color/ttc_on_gold"
        app:fabSize="normal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
