<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingVertical="10dp">

    <FrameLayout
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_icon_tile_neutral">
        <ImageView android:id="@+id/iv_stroke_icon"
            android:layout_width="20dp" android:layout_height="20dp"
            android:layout_gravity="center"
            app:tint="@color/ttc_text_2"
            android:contentDescription="@null"
            tools:src="@drawable/ic_skill_forehand" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_stroke_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TTC.Title.Card"
            tools:text="Forehand drive" />
        <TextView android:id="@+id/tv_meta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
            tools:text="Today · 12 min" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tv_accuracy"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TTC.Stat.Small"
            tools:text="87%" />
        <TextView android:id="@+id/tv_trend"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:drawablePadding="3dp"
            android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
            tools:text="4" />
    </LinearLayout>
</LinearLayout>
