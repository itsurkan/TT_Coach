<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ttc_canvas"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <ImageButton android:id="@+id/btnBack"
            android:layout_width="34dp" android:layout_height="34dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_link_icon_tile"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/ttc_text_1" android:padding="7dp"
            android:contentDescription="@string/cd_back" />
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/community_title"
            android:textAppearance="@style/TextAppearance.TTC.Title.Screen" />
    </LinearLayout>

    <!-- Search field -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxCornerRadiusBottomEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusTopStart="10dp"
        app:boxBackgroundColor="@color/ttc_sink"
        app:boxStrokeColor="@color/ttc_outline_strong"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1dp"
        app:hintEnabled="false"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCommunitySearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/community_search_hint"
            android:inputType="text"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.TTC.Body"
            android:textColor="@color/ttc_text_1"
            android:textColorHint="@color/ttc_text_3" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Sort chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupSort"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:singleSelection="true"
        app:selectionRequired="true">
        <com.google.android.material.chip.Chip android:id="@+id/chipSortRating"
            style="@style/TTC.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:checked="true" android:text="@string/community_sort_rating" />
        <com.google.android.material.chip.Chip android:id="@+id/chipSortNewest"
            style="@style/TTC.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/community_sort_newest" />
        <com.google.android.material.chip.Chip android:id="@+id/chipSortCreator"
            style="@style/TTC.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/community_sort_creator" />
    </com.google.android.material.chip.ChipGroup>

    <!-- List / loading / empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCommunity"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <ProgressBar
            android:id="@+id/progressCommunity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvCommunityEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/community_empty_state"
            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
