<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/ttc_canvas">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: chevron + eyebrow + title + subtitle + share icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_link_icon_tile"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/ttc_text_1"
                android:padding="7dp"
                android:contentDescription="@string/cd_back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/review_eyebrow"
                    android:textAppearance="@style/TextAppearance.TTC.Eyebrow.Gold" />
                <TextView
                    android:id="@+id/tv_drill_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TTC.Title.Screen"
                    tools:text="Forehand drive" />
                <TextView
                    android:id="@+id/tv_when"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                    tools:text="Today · 14:32 · 12 min" />
            </LinearLayout>

            <ImageView
                android:layout_width="34dp" android:layout_height="34dp"
                android:padding="7dp"
                android:src="@drawable/ic_share"
                app:tint="@color/ttc_text_3"
                android:contentDescription="@string/cd_share" />
        </LinearLayout>

        <!-- KPI strip -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:baselineAligned="false"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_kpi_accuracy"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TTC.Stat.Hero"
                    android:textColor="@color/ttc_gold_accent" tools:text="87%" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/review_kpi_accuracy"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_kpi_strokes"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TTC.Stat.Hero" tools:text="143" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/review_kpi_strokes"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_kpi_duration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TTC.Stat.Hero" tools:text="12m" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/review_kpi_duration"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- ACCURACY THROUGH SESSION card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/TTC.Card"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/review_accuracy_card_title"
                        android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />
                    <TextView android:id="@+id/tv_peak_pill"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:paddingHorizontal="10dp" android:paddingVertical="3dp"
                        android:background="@drawable/bg_pill_gold_container"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_gold_accent" tools:text="Peak 91%" />
                </LinearLayout>
                <com.ttcoachai.views.AccuracyLineChartView
                    android:id="@+id/chart_accuracy"
                    android:layout_width="match_parent" android:layout_height="140dp"
                    android:layout_marginTop="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <TextView android:id="@+id/tv_x_start"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start"
                        android:text="@string/review_x_label_start"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta" />
                    <TextView android:id="@+id/tv_x_mid"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta" tools:text="6 min" />
                    <TextView android:id="@+id/tv_x_end"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="end"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta" tools:text="12 min" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/review_accuracy_caption"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SHOT QUALITY card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/TTC.Card"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:id="@+id/tv_shot_quality_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TTC.Eyebrow" tools:text="SHOT QUALITY · 143 strokes" />
                <com.ttcoachai.views.ShotQualityBarView
                    android:id="@+id/bar_shot_quality"
                    android:layout_width="match_parent" android:layout_height="12dp"
                    android:layout_marginTop="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="10dp">
                    <TextView android:id="@+id/tv_legend_clean"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:textAppearance="@style/TextAppearance.TTC.Body"
                        android:textColor="@color/ttc_gold_accent" tools:text="Clean 118" />
                    <TextView android:id="@+id/tv_legend_error"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.TTC.Body"
                        android:textColor="@color/ttc_shot_error" tools:text="Error 25" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TOP FOCUS AREAS card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/TTC.Card"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/review_focus_title"
                    android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
                    android:layout_marginBottom="4dp" />
                <LinearLayout android:id="@+id/focus_container"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" />
                <TextView android:id="@+id/tv_view_all_focus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.TTC.Body"
                    android:textColor="@color/ttc_gold_accent"
                    android:visibility="gone" tools:text="View all 5 focus areas ›" />
                <TextView android:id="@+id/tv_focus_empty"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/review_no_analytics"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI COACH SUMMARY card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/TTC.Card.GoldTint"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="@color/ttc_gold_accent"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/review_summary_title"
                        android:textAppearance="@style/TextAppearance.TTC.Eyebrow.Gold" />
                </LinearLayout>
                <TextView android:id="@+id/tv_summary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TTC.Body"
                    android:textColor="@color/ttc_text_1" tools:text="You peaked at 91% accuracy..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_train_again"
            style="@style/TTC.Button.Primary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/review_action_train_again" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_overview"
            style="@style/TTC.Button.Ghost"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/review_action_overview" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
