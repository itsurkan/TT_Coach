<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ttc_canvas">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="96dp">

            <!-- ===================== Header row ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:baselineAligned="true"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/greeting_evening"
                        android:textAppearance="@style/TextAppearance.TTC.Title.Screen"
                        android:textColor="@color/ttc_text_1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_greeting_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/greeting_name_fallback"
                        android:textAppearance="@style/TextAppearance.TTC.Title.Screen"
                        android:textColor="@color/ttc_text_1"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/avatar_container"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/circle_gold"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <TextView
                        android:id="@+id/tv_avatar_initial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="@color/ttc_on_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/cd_avatar" />
                </FrameLayout>
            </LinearLayout>

            <!-- ===================== LAST SESSION card ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_last_session"
                style="@style/TTC.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:contentPadding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/eyebrow_last_session"
                            android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

                        <TextView
                            android:id="@+id/tv_last_when"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_dash_dash"
                            android:textAppearance="@style/TextAppearance.TTC.Mono.Meta" />
                    </LinearLayout>

                    <!-- Drill name row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="14dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_tile_neutral"
                            android:src="@drawable/ic_trending_up"
                            android:padding="10dp"
                            app:tint="@color/ttc_text_1"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tv_last_drill"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="@string/placeholder_no_sessions"
                            android:textAppearance="@style/TextAppearance.TTC.Title.Card"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Metrics panel -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_metric_panel"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_ls_strokes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash_dash"
                                android:textAppearance="@style/TextAppearance.TTC.Stat.Large"
                                android:textColor="@color/ttc_text_1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/eyebrow_strokes"
                                android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/ttc_outline" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_ls_accuracy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash_dash"
                                android:textAppearance="@style/TextAppearance.TTC.Stat.Large"
                                android:textColor="@color/ttc_gold_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/eyebrow_accuracy"
                                android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/ttc_outline" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_ls_consistency"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash_dash"
                                android:textAppearance="@style/TextAppearance.TTC.Stat.Large"
                                android:textColor="@color/ttc_success" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/eyebrow_consistency"
                                android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- View full report row -->
                    <LinearLayout
                        android:id="@+id/row_full_report"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_file"
                            app:tint="@color/ttc_gold_accent"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/action_view_full_report"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textColor="@color/ttc_text_1" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/ttc_text_3"
                            android:contentDescription="@null" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== THIS WEEK card ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_this_week"
                style="@style/TTC.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:contentPadding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/eyebrow_this_week"
                            android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

                        <LinearLayout
                            android:id="@+id/pill_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_pill_gold_container"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_flame"
                                app:tint="@color/ttc_gold_accent"
                                android:contentDescription="@null" />

                            <TextView
                                android:id="@+id/tv_streak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/placeholder_dash_dash"
                                android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
                                android:textColor="@color/ttc_gold_accent" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bar chart -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="18dp"
                        android:baselineAligned="false">

                        <!-- Column 0 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_0"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_mon_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <!-- Column 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_1"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_tue_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <!-- Column 2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_2"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_wed_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <!-- Column 3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_3"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_thu_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <!-- Column 4 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_4"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_fri_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <!-- Column 5 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_5"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_sat_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>

                        <!-- Column 6 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="56dp">

                                <View
                                    android:id="@+id/bar_6"
                                    android:layout_width="22dp"
                                    android:layout_height="4dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/bg_bar_empty" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/lbl_6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/dow_sun_short"
                                android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                                android:textColor="@color/ttc_text_3" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Weekly goal row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_weekly_goal"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />

                        <TextView
                            android:id="@+id/tv_weekly_sessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_dash_dash"
                            android:textAppearance="@style/TextAppearance.TTC.Stat.Small"
                            android:textColor="@color/ttc_text_1" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_weekly"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/ttc_gold_bright"
                        android:progressBackgroundTint="@color/ttc_sink" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_begin_session"
        style="@style/TTC.Fab.Extended"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/btn_new_session"
        app:icon="@drawable/ic_camera" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
