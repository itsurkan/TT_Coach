<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ttc_canvas"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/ttc_outline" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pause_resume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:text="@string/btn_resume"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            android:layout_marginEnd="8dp"
            style="@style/TTC.Button.Ghost"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_end_session"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:text="@string/btn_end_session"
            android:layout_marginStart="8dp"
            style="@style/TTC.Button.Danger"/>

    </LinearLayout>

    <!-- Session Focus card: consolidated stats + drill info -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    style="@style/TTC.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/live_session_focus"/>

                <TextView
                    android:id="@+id/tv_accuracy"
                    style="@style/TextAppearance.TTC.Stat.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_percent"
                    android:textColor="@color/ttc_gold_accent"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_drill_name"
                style="@style/TextAppearance.TTC.Title.Card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/training_session_title"/>

            <ProgressBar
                android:id="@+id/progress_drill"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressDrawable="@drawable/bg_progressbar_gold"
                android:progress="0"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_drill_progress"
                    style="@style/TextAppearance.TTC.Mono.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hits_progress_format"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/dot_separator"
                    android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                    android:textColor="@color/ttc_text_2"/>

                <TextView
                    android:id="@+id/tv_total_hits"
                    style="@style/TextAppearance.TTC.Mono.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/placeholder_hits"
                    android:textColor="@color/ttc_text_2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/label_total_hits"
                    android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                    android:textColor="@color/ttc_text_2"/>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- AI Coach Tip -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card.GoldTint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/live_ai_coach"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_ai_tip"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tip_camera_position"
                android:textColor="@color/ttc_text_1"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Real-time Feedback List (1a/1e) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <TextView
            style="@style/TTC.SectionHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/live_realtime_feedback"/>

        <TextView
            android:id="@+id/tv_flagged"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_feedback_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:descendantFocusability="blocksDescendants"
        android:layout_marginBottom="16dp"/>

    <!-- Full session report card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_full_report"
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_target"
                app:tint="@color/ttc_gold_accent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/live_full_report_title"
                    android:textAppearance="@style/TextAppearance.TTC.Title.Card" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/live_full_report_sub"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/live_premium_badge"
                android:background="@drawable/bg_pill_premium"
                android:textAppearance="@style/TextAppearance.TTC.Eyebrow"
                android:textAllCaps="true"
                android:textColor="@color/ttc_gold_accent"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Feedback Settings (subordinate debug section) -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_sliders"
                    app:tint="@color/ttc_text_2" />

                <TextView
                    style="@style/TTC.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/live_feedback_settings" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/live_feedback_cadence"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />

            </LinearLayout>

            <TextView
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_frequency_n"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinner_frequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/feedback_frequencies"
                android:paddingBottom="8dp" />

            <TextView
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_enabled_corrections"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <CheckBox
                android:id="@+id/cb_wrist"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_wrist_angle"/>

            <CheckBox
                android:id="@+id/cb_body_rotation"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_body_rotation"/>

            <CheckBox
                android:id="@+id/cb_follow_through"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_follow_through"/>

            <CheckBox
                android:id="@+id/cb_contact_height"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_contact_height"/>

            <CheckBox
                android:id="@+id/cb_elbow_position"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_elbow_position"/>

            <CheckBox
                android:id="@+id/cb_stroke_speed"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_stroke_speed"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
