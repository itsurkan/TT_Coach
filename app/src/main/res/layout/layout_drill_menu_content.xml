<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ttc_canvas"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/ttc_outline" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pause_resume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:text="@string/btn_resume"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            android:layout_marginEnd="8dp"
            style="@style/TTC.Button.Ghost"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_end_session"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:text="@string/btn_end_session"
            android:layout_marginStart="8dp"
            style="@style/TTC.Button.Danger"/>

    </LinearLayout>

    <!-- Session Focus card: consolidated stats + drill info -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    style="@style/TTC.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/live_session_focus"/>

                <TextView
                    android:id="@+id/tv_accuracy"
                    style="@style/TextAppearance.TTC.Stat.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_percent"
                    android:textColor="@color/ttc_gold_accent"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_drill_name"
                style="@style/TextAppearance.TTC.Title.Card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/training_session_title"/>

            <ProgressBar
                android:id="@+id/progress_drill"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressDrawable="@drawable/bg_progressbar_gold"
                android:progress="0"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_drill_progress"
                    style="@style/TextAppearance.TTC.Mono.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hits_progress_format"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/dot_separator"
                    android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                    android:textColor="@color/ttc_text_2"/>

                <TextView
                    android:id="@+id/tv_total_hits"
                    style="@style/TextAppearance.TTC.Mono.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/placeholder_hits"
                    android:textColor="@color/ttc_text_2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/label_total_hits"
                    android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                    android:textColor="@color/ttc_text_2"/>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- AI Coach Tip -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card.GoldTint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/live_ai_coach"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_ai_tip"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tip_camera_position"
                android:textColor="@color/ttc_text_1"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Real-time Feedback List (1a/1e) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <TextView
            style="@style/TTC.SectionHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/live_realtime_feedback"/>

        <TextView
            android:id="@+id/tv_flagged"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_feedback_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:descendantFocusability="blocksDescendants"
        android:layout_marginBottom="16dp"/>

    <!-- Feedback Settings (subordinate debug section) -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/header_feedback_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_sliders"
                    app:tint="@color/ttc_text_2" />

                <TextView
                    style="@style/TTC.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/live_feedback_settings" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/live_feedback_cadence"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />

                <ImageView
                    android:id="@+id/iv_feedback_settings_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="@string/alt_feedback_settings_toggle"
                    app:tint="@color/ttc_text_2" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/group_feedback_settings_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.TTC.Title.Card"
                android:textSize="13.5sp"
                android:text="@string/feedback_cues_per_session"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/toggle_cues_per_session"
                style="@style/TTC.SegmentedTrack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cues_3"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingVertical="10dp"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_tight_semibold"
                    app:strokeWidth="0dp"
                    app:elevation="0dp"
                    app:cornerRadius="999dp"
                    android:text="3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cues_5"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingVertical="10dp"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_tight_semibold"
                    app:strokeWidth="0dp"
                    app:elevation="0dp"
                    app:cornerRadius="999dp"
                    android:text="5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cues_10"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingVertical="10dp"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_tight_semibold"
                    app:strokeWidth="0dp"
                    app:elevation="0dp"
                    app:cornerRadius="999dp"
                    android:text="10" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TTC.SectionHeader.Gold"
                android:text="@string/feedback_section_corrections"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_corrections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleLine="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_wrist"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/correction_wrist" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_rotation"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/correction_rotation" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_follow_through"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/correction_follow_through" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_contact_height"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/correction_contact_height" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_elbow"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/correction_elbow" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_knee_bend"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/correction_knee_bend" />
            </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Full session report card (ends the session — kept last so it's not above frequently-used controls) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_full_report"
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_target"
                app:tint="@color/ttc_gold_accent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/live_full_report_title"
                    android:textAppearance="@style/TextAppearance.TTC.Title.Card" />

                <TextView
                    android:id="@+id/tv_full_report_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/live_full_report_sub"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                    android:visibility="visible" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
