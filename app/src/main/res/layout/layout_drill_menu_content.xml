<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ttc_canvas"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/ttc_outline" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pause_resume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:text="@string/btn_resume"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            android:layout_marginEnd="8dp"
            style="@style/TTC.Button.Ghost"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_end_session"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:text="@string/btn_end_session"
            android:layout_marginStart="8dp"
            style="@style/TTC.Button.Danger"/>

    </LinearLayout>

    <!-- Session Stats -->
    <TextView
        style="@style/TTC.SectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_focus_consistency"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            style="@style/TTC.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_total_hits"
                    style="@style/TextAppearance.TTC.Stat.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_hits"
                    android:textColor="@color/ttc_gold_accent"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    style="@style/TextAppearance.TTC.Body.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_hits"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/TTC.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_accuracy"
                    style="@style/TextAppearance.TTC.Stat.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_percent"
                    android:textColor="@color/ttc_gold_accent"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    style="@style/TextAppearance.TTC.Body.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_accuracy"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Current Drill Info -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_drill_name"
                style="@style/TextAppearance.TTC.Title.Card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/training_session_title"
                android:layout_marginBottom="2dp"/>

            <TextView
                style="@style/TextAppearance.TTC.Body.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_focus_consistency"
                android:layout_marginBottom="12dp"/>

            <ProgressBar
                android:id="@+id/progress_drill"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginBottom="8dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressDrawable="@drawable/bg_progressbar_gold"
                android:progress="0"/>

            <TextView
                android:id="@+id/tv_drill_progress"
                style="@style/TextAppearance.TTC.Body.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hits_progress_format"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- AI Coach Tip -->
    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card.GoldTint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/live_ai_coach"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_ai_tip"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tip_camera_position"
                android:textColor="@color/ttc_text_1"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Real-time Feedback List -->
    <TextView
        style="@style/TTC.SectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/live_realtime_feedback"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_feedback_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:descendantFocusability="blocksDescendants"
        android:layout_marginBottom="16dp"/>

    <!-- Feedback Settings -->
    <TextView
        style="@style/TTC.SectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/header_feedback_settings_debug"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.card.MaterialCardView
        style="@style/TTC.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.TTC.Body.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_frequency_n"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinner_frequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/feedback_frequencies"
                android:paddingBottom="8dp" />

            <TextView
                style="@style/TextAppearance.TTC.Body.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_enabled_corrections"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <CheckBox
                android:id="@+id/cb_wrist"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_wrist_angle"/>

            <CheckBox
                android:id="@+id/cb_body_rotation"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_body_rotation"/>

            <CheckBox
                android:id="@+id/cb_follow_through"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_follow_through"/>

            <CheckBox
                android:id="@+id/cb_contact_height"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_contact_height"/>

            <CheckBox
                android:id="@+id/cb_elbow_position"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_elbow_position"/>

            <CheckBox
                android:id="@+id/cb_stroke_speed"
                style="@style/TextAppearance.TTC.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/correction_stroke_speed"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
