<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/ttc_canvas">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_screen_title"
                android:textAppearance="@style/TextAppearance.TTC.Title.Screen" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_subtitle"
                android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp"/>

            <!-- ===================== AI Coach ===================== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sparkle"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_section_ai_coach"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TTC.Card"
                app:contentPadding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Select Coach -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_choose_coach"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_choose_coach_sub"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="12dp"/>

                        <!-- Pill segmented control: plain pill track + segments styled manually in SettingsFragment -->
                        <LinearLayout
                            android:id="@+id/toggle_coach_style"
                            style="@style/TTC.SegmentedTrack"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_coach_vadym"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/coach_vadym_name" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_coach_Ivan"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/coach_ivan_name" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_coach_Andriy"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/coach_andriy_name" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Coach Info Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/layout_coach_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        style="@style/TTC.Card.GoldTint"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">

                            <!-- Coach Avatar -->
                            <TextView
                                android:id="@+id/tv_coach_avatar"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:text="@string/label_version_character"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/ttc_on_gold"
                                android:background="@drawable/circle_gold"
                                android:gravity="center"
                                android:layout_marginEnd="12dp"/>

                            <!-- Coach Details -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_coach_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/coach_vadym_name"
                                    android:textStyle="bold"
                                    android:textColor="@color/ttc_gold_accent"
                                    android:textSize="16sp"/>

                                <TextView
                                    android:id="@+id/tv_coach_style"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/coach_vadym_style"
                                    android:textColor="@color/ttc_gold_accent"
                                    android:textSize="14sp"
                                    android:layout_marginTop="2dp"/>

                                <TextView
                                    android:id="@+id/tv_coach_desc"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/coach_vadym_desc"
                                    android:textColor="@color/ttc_text_on_gold_card"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== Language ===================== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_language"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_section_language"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TTC.Card"
                app:contentPadding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:divider="?android:attr/listDivider"
                    android:showDividers="middle">

                    <!-- Interface language -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_interface_language"
                                android:textAppearance="@style/TextAppearance.TTC.Body"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_interface_language_sub"
                                android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Pill segmented control: plain pill track + segments styled manually in SettingsFragment -->
                        <LinearLayout
                            android:id="@+id/toggle_interface_lang"
                            style="@style/TTC.SegmentedTrack"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_iface_en"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/lang_en" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_iface_uk"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/lang_uk" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Coach language -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_coach_language"
                                android:textAppearance="@style/TextAppearance.TTC.Body"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_coach_language_sub"
                                android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Pill segmented control: plain pill track + segments styled manually in SettingsFragment -->
                        <LinearLayout
                            android:id="@+id/toggle_coach_lang"
                            style="@style/TTC.SegmentedTrack"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_coach_lang_en"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/lang_en" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_coach_lang_uk"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/lang_uk" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== Feedback & detection ===================== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_activity"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_section_feedback_detection"/>
            </LinearLayout>

            <!-- Feedback link row -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TTC.Card"
                app:contentPadding="12dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_link_icon_tile"
                        android:src="@drawable/ic_sliders"
                        app:tint="@color/ttc_gold_accent"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_link_feedback"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_link_feedback_sub"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/ttc_text_faint"
                        android:contentDescription="@null"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Detection link row -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_detection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TTC.Card"
                app:contentPadding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_link_icon_tile"
                        android:src="@drawable/ic_target"
                        app:tint="@color/ttc_gold_accent"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_link_detection"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_link_detection_sub"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/ttc_text_faint"
                        android:contentDescription="@null"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== Camera ===================== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/ttc_gold_accent"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"/>

                <TextView
                    style="@style/TTC.SectionHeader.Gold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_section_camera"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TTC.Card"
                app:contentPadding="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:divider="?android:attr/listDivider"
                    android:showDividers="middle">

                    <!-- Video Quality -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_video_quality"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_video_quality_sub"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="12dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/auto_complete_video_quality"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:padding="12dp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Frame Rate -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_frame_rate"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_frame_rate_sub"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="12dp"/>

                        <!-- Pill segmented control: plain pill track + segments styled manually in SettingsFragment -->
                        <LinearLayout
                            android:id="@+id/toggle_fps"
                            style="@style/TTC.SegmentedTrack"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_fps_24"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/fps_24" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_fps_30"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/fps_30" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_fps_60"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingVertical="10dp"
                                android:textAllCaps="false"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_tight_semibold"
                                app:strokeWidth="0dp"
                                app:elevation="0dp"
                                app:cornerRadius="999dp"
                                android:text="@string/fps_60" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pose Skeleton -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_show_skeleton"
                                android:textAppearance="@style/TextAppearance.TTC.Body"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_show_skeleton_sub"
                                android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_pose_skeleton"
                            style="@style/TTC.Toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== Tip ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TTC.Card.GoldTint"
                app:contentPadding="16dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="@color/ttc_gold_accent"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_tip"
                            android:textAppearance="@style/TextAppearance.TTC.Eyebrow.Gold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_tip_body"
                            android:textAppearance="@style/TextAppearance.TTC.Body"
                            android:textColor="@color/ttc_text_2"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
