<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/progress_title"
                android:textAppearance="@style/TextAppearance.TTC.Title.Screen"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/progress_subtitle"
                android:textAppearance="@style/TextAppearance.TTC.Body" />

            <!-- Stats Overview Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Days Streak -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    app:contentPadding="0dp"
                    style="@style/TTC.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="14dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_icon_tile_gold">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/ttc_gold_accent" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_days_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textAppearance="@style/TextAppearance.TTC.Stat.Medium"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:maxLines="1"
                            app:autoSizeTextType="uniform"
                            app:autoSizeMinTextSize="8sp"
                            app:autoSizeMaxTextSize="12sp"
                            android:text="@string/stats_days_streak"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total Hours -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:contentPadding="0dp"
                    style="@style/TTC.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="14dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_icon_tile_neutral">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_target"
                                app:tint="@color/ttc_text_2" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_total_hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textAppearance="@style/TextAppearance.TTC.Stat.Medium"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:maxLines="1"
                            app:autoSizeTextType="uniform"
                            app:autoSizeMinTextSize="8sp"
                            app:autoSizeMaxTextSize="12sp"
                            android:text="@string/stats_total_hours"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Achievements -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    app:contentPadding="0dp"
                    style="@style/TTC.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="14dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_icon_tile_gold">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_award"
                                app:tint="@color/ttc_gold_accent" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_achievements"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textAppearance="@style/TextAppearance.TTC.Stat.Medium"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:maxLines="1"
                            app:autoSizeTextType="uniform"
                            app:autoSizeMinTextSize="8sp"
                            app:autoSizeMaxTextSize="12sp"
                            android:text="@string/stats_achievements"
                            android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Charts Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:contentPadding="0dp"
                style="@style/TTC.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Pill segmented control: plain pill track + two segments styled manually in ProgressFragment -->
                    <LinearLayout
                        android:id="@+id/toggle_group_chart"
                        style="@style/TTC.SegmentedTrack"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_training_time"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:minHeight="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingVertical="10dp"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_tight_semibold"
                            app:strokeWidth="0dp"
                            app:elevation="0dp"
                            app:cornerRadius="999dp"
                            android:text="@string/tab_training_time" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_accuracy"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:minHeight="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:paddingVertical="10dp"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_tight_semibold"
                            app:strokeWidth="0dp"
                            app:elevation="0dp"
                            app:cornerRadius="999dp"
                            android:text="@string/tab_accuracy" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_chart_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chart_training_title"
                        android:textAppearance="@style/TextAppearance.TTC.Title.Card"/>

                    <TextView
                        android:id="@+id/tv_chart_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chart_training_subtitle"
                        android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                        android:layout_marginBottom="16dp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/training_bar_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/accuracy_line_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Skill Breakdown Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:contentPadding="0dp"
                style="@style/TTC.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_trending_up"
                            app:tint="@color/ttc_gold_accent"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/skill_levels_title"
                            android:textAppearance="@style/TextAppearance.TTC.Title.Card"/>
                    </LinearLayout>

                    <!-- Skills Container (Populated dynamically) -->
                    <LinearLayout
                        android:id="@+id/skills_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Milestones Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:contentPadding="0dp"
                style="@style/TTC.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/milestones_title"
                        android:textAppearance="@style/TextAppearance.TTC.Title.Card"
                        android:layout_marginBottom="16dp"/>

                    <!-- Milestones Container (Populated dynamically) -->
                    <LinearLayout
                        android:id="@+id/milestones_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
