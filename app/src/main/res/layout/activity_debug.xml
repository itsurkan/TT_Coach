<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".DebugActivity">

    <!-- Top Bar: Video Info -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/design_default_color_primary"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvVideoInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No video loaded"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnLoadVideo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📂 Load Video"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnLogPoses"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="💾 Log Poses"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:enabled="false" />



            <Button
                android:id="@+id/btnToggleViewMode"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📱 Portrait Mode"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnTestAudio"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🔊 Test Audio"
                android:textSize="12sp"
                android:backgroundTint="#FF5722" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content: Split Screen -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Left Panel: Video Player with Overlay -->
        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/black">

            <VideoView
                android:id="@+id/videoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <!-- ImageView for displaying frames when seeking (VideoView can't do this) -->
            <ImageView
                android:id="@+id/frameImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <com.google.mediapipe.examples.poselandmarker.OverlayView
                android:id="@+id/overlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Right Panel: Analysis Results -->
        <ScrollView
            android:id="@+id/analysisPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Portrait Mode Top Controls (hidden by default) -->
                <LinearLayout
                    android:id="@+id/portraitTopControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tvVideoInfoPortrait"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No video loaded"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        android:paddingBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnLoadVideoPortrait"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="📂 Load"
                            android:textSize="11sp"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btnLogPosesPortrait"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="💾 Log"
                            android:textSize="11sp"
                            android:layout_marginEnd="4dp"
                            android:enabled="false" />

                        <Button
                            android:id="@+id/btnToggleViewModePortrait"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="🖥 Landscape"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnTestAudioPortrait"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="🔊 Test"
                            android:textSize="11sp"
                            android:backgroundTint="#FF5722"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:layout_marginVertical="8dp" />
                </LinearLayout>

                <!-- Current Frame Analysis -->
                <TextView
                    android:id="@+id/headerCurrentFrame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▼ 📊 Current Frame"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/contentCurrentFrame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvFrameNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Frame: 0 / 0"
                        android:textSize="14sp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvPhase"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phase: READY"
                        android:textSize="14sp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Score: 0%"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:layout_marginVertical="4dp" />

                <!-- Current Feedback -->
                <TextView
                    android:id="@+id/headerFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▼ 💬 Feedback"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/contentFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvCurrentFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:layout_marginVertical="4dp" />

                <!-- Session Summary -->
                <TextView
                    android:id="@+id/headerSessionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶ 📈 Session Summary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/contentSessionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvTotalFrames"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total Frames: 0"
                        android:textSize="13sp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvStrokesDetected"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Strokes Detected: 0"
                        android:textSize="13sp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvAvgScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Avg Score: 0%"
                        android:textSize="13sp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvGoodStrokes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Good Strokes: 0"
                        android:textSize="13sp"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/tvPhaseDistribution"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phase Distribution:\n--"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:paddingBottom="8dp" />

                    <Button
                        android:id="@+id/btnReset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔄 Reset Analysis" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:layout_marginVertical="4dp" />

                <!-- Playback Controls -->
                <TextView
                    android:id="@+id/headerPlayback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▼ 🎮 Playback Controls"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/contentPlayback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp">

                    <!-- Frame Scrubber -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Frame:"
                            android:textSize="12sp"
                            android:paddingEnd="8dp" />

                        <SeekBar
                            android:id="@+id/seekBarFrame"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100" />
                    </LinearLayout>

                    <!-- Play/Pause and Step Controls -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp">

                        <Button
                            android:id="@+id/btnStepBack"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="⏮"
                            android:textSize="18sp"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btnPlayPause"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="2"
                            android:text="▶ Play"
                            android:textSize="14sp"
                            android:layout_marginHorizontal="4dp" />

                        <Button
                            android:id="@+id/btnStepForward"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="⏭"
                            android:textSize="18sp"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <!-- Speed Controls -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Speed:"
                            android:textSize="12sp"
                            android:paddingEnd="8dp" />

                        <Button
                            android:id="@+id/btnSpeed025x"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="0.25x"
                            android:textSize="11sp"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btnSpeed05x"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="0.5x"
                            android:textSize="11sp"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btnSpeed1x"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="1x"
                            android:textSize="11sp"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btnSpeed2x"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="2x"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:layout_marginVertical="4dp" />

                <!-- Technical Parameters -->
                <TextView
                    android:id="@+id/headerTechnical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶ 🎯 Technical Parameters"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/contentTechnical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvWristAngle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Wrist Angle: --"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvBodyRotation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Body Rotation: --"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvFollowThrough"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Follow-Through: --"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvContactHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Contact Height: --"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvElbowDistance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Elbow Distance: --"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:paddingBottom="4dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
