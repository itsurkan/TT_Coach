<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="?attr/colorSurface">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="48dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="@string/app_name" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/title_login"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/subtitle_login"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="64dp" />

    <!-- Google Login -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login_google"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_continue_google"
        app:icon="@drawable/ic_check_circle_2"
        app:iconTint="@null"
        android:layout_marginBottom="16dp" />

    <!-- Facebook Login -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login_facebook"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_continue_facebook"
        app:icon="@drawable/ic_check_circle_2"
        app:iconTint="@null"
        android:layout_marginBottom="16dp" />

    <!-- Apple Login -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login_apple"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_continue_apple"
        app:icon="@drawable/ic_check_circle_2"
        app:iconTint="@null"
        android:layout_marginBottom="16dp" />

</LinearLayout>
