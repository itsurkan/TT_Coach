<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ttc_canvas"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_editor_back"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_link_icon_tile"
                    android:contentDescription="@string/cd_back"
                    android:padding="7dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/ttc_text_1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_editor_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/exercise_editor_title_new"
                            android:textAppearance="@style/TextAppearance.TTC.Title.Screen" />

                        <TextView
                            android:id="@+id/tv_editor_copy_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_pill_gold_container"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="@string/exercise_editor_copy_badge"
                            android:textAppearance="@style/TextAppearance.TTC.Eyebrow.Gold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_editor_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/TextAppearance.TTC.Body.Secondary"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- NAME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/exercise_editor_name_label"
                android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxCornerRadiusBottomEnd="11dp"
                app:boxCornerRadiusBottomStart="11dp"
                app:boxCornerRadiusTopEnd="11dp"
                app:boxCornerRadiusTopStart="11dp"
                app:boxStrokeColor="@color/ttc_gold_bright"
                app:hintEnabled="false"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_editor_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/exercise_editor_name_hint"
                    android:textAppearance="@style/TextAppearance.TTC.Body"
                    android:textColor="@color/ttc_text_1"
                    android:textColorHint="@color/ttc_text_3" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- FOCUS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/exercise_editor_focus_label"
                android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_focus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:singleLine="false"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_focus_arm"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/focus_arm" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_focus_shoulders"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/focus_shoulders" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_focus_legs"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/focus_legs" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_focus_core"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/focus_core" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_focus_hips"
                    style="@style/TTC.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/focus_hips" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/tv_active_metrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:textAppearance="@style/TextAppearance.TTC.Body"
                android:textColor="@color/ttc_text_3" />

            <!-- REFERENCE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/exercise_editor_reference_label"
                android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

            <RadioGroup
                android:id="@+id/rg_reference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb_reference_baseline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:buttonTint="@color/ttc_gold_bright"
                    android:text="@string/exercise_editor_reference_baseline"
                    android:textAppearance="@style/TextAppearance.TTC.Body"
                    android:textColor="@color/ttc_text_1" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb_reference_standard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/ttc_gold_bright"
                    android:text="@string/exercise_editor_reference_standard"
                    android:textAppearance="@style/TextAppearance.TTC.Body"
                    android:textColor="@color/ttc_text_1" />
            </RadioGroup>

            <!-- STRICTNESS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/exercise_editor_strictness_label"
                    android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

                <TextView
                    android:id="@+id/tv_strictness_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="×1.00"
                    android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                    android:textColor="@color/ttc_gold_accent" />
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_strictness"
                style="@style/TTC.Slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:stepSize="0.05"
                android:value="1.0"
                android:valueFrom="0.5"
                android:valueTo="2.0" />

            <!-- Advanced — per-phase targets -->
            <LinearLayout
                android:id="@+id/row_advanced_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/exercise_editor_advanced_header"
                    android:textAppearance="@style/TextAppearance.TTC.Title.Card" />

                <ImageView
                    android:id="@+id/iv_advanced_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="@color/ttc_text_2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_advanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:text="@string/exercise_editor_advanced_hint"
                    android:textAppearance="@style/TextAppearance.TTC.Body.Secondary" />

                <!-- Column headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_col_metric"
                        android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/exercise_editor_col_from"
                        android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/exercise_editor_col_to"
                        android:textAppearance="@style/TextAppearance.TTC.Eyebrow" />
                </LinearLayout>

                <!-- Row: elbow · backswing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_elbow_backswing"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_elbow_backswing_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="145"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_elbow_backswing_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="175"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: elbow · finish -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_elbow_finish"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_elbow_finish_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="60"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_elbow_finish_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="85"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: shoulder · backswing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_shoulder_backswing"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_shoulder_backswing_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="20"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_shoulder_backswing_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="60"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: shoulder · finish -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_shoulder_finish"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_shoulder_finish_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="80"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_shoulder_finish_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="130"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: knees · backswing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_knees_backswing"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_knees_backswing_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="110"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_knees_backswing_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="130"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: knees · strike -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_knees_strike"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_knees_strike_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="110"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_knees_strike_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="130"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: hips · backswing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_hips_backswing"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_hips_backswing_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="115"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_hips_backswing_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="160"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: hips · strike -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_hips_strike"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_hips_strike_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="120"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_hips_strike_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="165"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: torso tilt · backswing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_torso_backswing"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_torso_backswing_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="25"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_torso_backswing_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="45"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

                <!-- Row: torso tilt · strike -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/exercise_editor_row_torso_strike"
                        android:textAppearance="@style/TextAppearance.TTC.Body" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_torso_strike_from"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="25"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_torso_strike_to"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_track"
                        android:gravity="center"
                        android:hint="45"
                        android:inputType="number"
                        android:paddingHorizontal="4dp"
                        android:textAppearance="@style/TextAppearance.TTC.Mono.Meta"
                        android:textColor="@color/ttc_text_1" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ttc_canvas"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_editor_cancel"
            style="@style/TTC.Button.Ghost"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="@string/exercise_editor_action_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_editor_primary"
            style="@style/TTC.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/exercise_editor_action_create" />
    </LinearLayout>

</LinearLayout>
