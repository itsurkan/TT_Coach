<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_dashboard">

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.DashboardFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_progress"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.ProgressFragment"
        android:label="@string/title_progress"
        tools:layout="@layout/fragment_progress" />

    <fragment
        android:id="@+id/navigation_drills"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.DrillsFragment"
        android:label="@string/title_drills"
        tools:layout="@layout/fragment_drills" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.ProfileFragment"
        android:label="@string/title_profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/permissions_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.PermissionsFragment"
        android:label="Permissions">
        <action
            android:id="@+id/action_permissions_to_camera"
            app:destination="@id/camera_fragment"
            app:popUpTo="@id/permissions_fragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/camera_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.CameraFragment"
        android:label="@string/menu_camera"
        tools:layout="@layout/fragment_camera">
        <action
            android:id="@+id/action_camera_to_permissions"
            app:destination="@id/permissions_fragment"
            app:popUpTo="@id/camera_fragment"
            app:popUpToInclusive="true" />
    </fragment>
    <activity
        android:id="@+id/navigation_developer"
        android:name="com.google.mediapipe.examples.poselandmarker.DebugActivity"
        android:label="Developer"
        tools:layout="@layout/activity_debug" />
</navigation>
