<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Dark background for dark theme -->
    <solid android:color="@color/spinner_bg" />
    
    <!-- Border to make it stand out in dark theme -->
    <stroke
        android:width="1dp"
        android:color="@color/spinner_border" />
    
    <!-- Rounded corners matching card style -->
    <corners android:radius="12dp" />
    
    <!-- Padding for content -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp" />
</shape>
