/*
 * AI Coach for Table Tennis
 * Training UI Controller - Manages UI updates and user interactions
 */

package com.ttcoachai.managers

import android.content.Context
import android.view.View
import android.widget.Toast
import com.ttcoachai.R
import com.ttcoachai.databinding.ActivityTrainingBinding

class TrainingUIController(
    private val context: Context,
    private val binding: ActivityTrainingBinding,
    private val stateManager: TrainingStateManager
) {
    
    fun setupInitialState() {
        binding.btnStartStop.isEnabled = false
        updateFeedbackText(context.getString(R.string.press_calibrate))
    }
    
    fun showCalibrationInProgress() {
        binding.tvCalibrationStatus.visibility = View.VISIBLE
        binding.tvCalibrationStatus.text = context.getString(R.string.calibration_prompt) + 
            "\n\n• Ноги на ширині плечей\n• Трохи присядьте\n• Ракетка перед собою"
        binding.btnCalibrate.isEnabled = false
        updateFeedbackText(context.getString(R.string.calibrating))
    }
    
    fun showCalibrationComplete(onComplete: () -> Unit) {
        binding.tvCalibrationStatus.text = "✅ Калібрування завершено!"
        binding.root.postDelayed({
            binding.tvCalibrationStatus.visibility = View.GONE
            binding.btnStartStop.isEnabled = true
            binding.btnCalibrate.isEnabled = true
            updateFeedbackText(context.getString(R.string.ready_to_train))
            Toast.makeText(context, context.getString(R.string.ready_toast), Toast.LENGTH_SHORT).show()
            onComplete()
        }, 1000)
    }
    
    fun showTrainingStarted() {
        binding.btnStartStop.text = context.getString(R.string.btn_pause)
        binding.btnStartStop.setBackgroundColor(
            (context as android.app.Activity).getColor(android.R.color.holo_red_light)
        )
        binding.btnCalibrate.isEnabled = false
        binding.layoutStats.visibility = View.VISIBLE
        updateFeedbackText("🏓 Тренування активне - виконуйте удари!")
    }
    
    fun showTrainingStopped() {
        binding.btnStartStop.text = "▶ Почати"
        binding.btnStartStop.setBackgroundColor(
            (context as android.app.Activity).getColor(android.R.color.holo_green_light)
        )
        binding.btnCalibrate.isEnabled = true
        binding.layoutStats.visibility = View.GONE
        updateFeedbackText(context.getString(R.string.training_paused))
    }
    
    fun updateStats() {
        binding.tvStrokeCount.text = context.getString(
            R.string.stroke_count, 
            stateManager.getStrokeCount()
        )
        binding.tvAverageScore.text = context.getString(
            R.string.accuracy, 
            stateManager.getAverageScore().toInt()
        )
    }
    
    fun updateFeedbackText(feedback: String) {
        binding.feedbackText.text = feedback
    }
    
    fun showSummaryDialog(onFinish: () -> Unit, onContinue: () -> Unit) {
        val summaryText = stateManager.getSummaryText()
        val improvementTip = stateManager.getImprovementTip()
        
        androidx.appcompat.app.AlertDialog.Builder(context)
            .setTitle(context.getString(R.string.training_summary))
            .setMessage("$summaryText\n\n$improvementTip")
            .setPositiveButton(context.getString(R.string.finish_button)) { dialog, which -> onFinish() }
            .setNegativeButton(context.getString(R.string.continue_button)) { dialog, which -> onContinue() }
            .show()
    }
    
    fun showFinishTrainingDialog(onYes: () -> Unit) {
        androidx.appcompat.app.AlertDialog.Builder(context)
            .setTitle(R.string.finish_training_title)
            .setMessage(R.string.finish_training_message)
            .setPositiveButton(R.string.dialog_yes) { _, _ -> onYes() }
            .setNegativeButton(R.string.dialog_no, null)
            .show()
    }
    
    fun simulateFeedback(onUpdate: () -> Unit) {
        val feedbackMessages = listOf(
            "👍 Гарний удар!",
            "⚠️ Тримайте ракетку трохи вище",
            "✅ Відмінна техніка!",
            "💪 Більше обертання тіла"
        )
        
        var feedbackIndex = 0
        val handler = android.os.Handler(android.os.Looper.getMainLooper())
        val feedbackRunnable = object : Runnable {
            override fun run() {
                if (stateManager.isTrainingActive && feedbackIndex < 20) {
                    updateFeedbackText(feedbackMessages.random())
                    feedbackIndex++
                    onUpdate()
                    handler.postDelayed(this, 2000)
                }
            }
        }
        handler.postDelayed(feedbackRunnable, 2000)
    }
}
